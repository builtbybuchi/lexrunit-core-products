{
  "version": "7.3",
  "routing_model": {
    "REGISTER_SCREEN": []
  },
  "screens": [
    {
      "id": "REGISTER_SCREEN",
      "title": "LexCare Registration",
      "terminal": true,
      "success": true,
      "data": {},
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Create Your Account"
          },
          {
            "type": "TextBody",
            "text": "Please provide your details to complete the setup of your LexCare profile."
          },
          {
            "type": "TextInput",
            "name": "full_name",
            "label": "Full Name",
            "required": true,
            "input-type": "text"
          },
          {
            "type": "DatePicker",
            "name": "dob",
            "label": "Date of Birth",
            "required": true
          },
          {
            "type": "Footer",
            "label": "Complete Registration",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "full_name": "${form.full_name}",
                "dob": "${form.dob}"
              }
            }
          }
        ]
      }
    }
  ]
}
